{
  "name": "student-reality-lab",
  "version": "1.0.0",
  "type": "module",
  "homepage": "https://Victor-Gutierrez4.github.io/student-reality-lab-Gutierrez",
  "scripts": {
     "predeploy": "npm run build",
   "deploy": "gh-pages -d build",
     "start": "npm run build && node dist/main.js",
     "build": "tsc",
     "dev": "concurrently \"npm:start --prefix mcp-tool\" \"npm:start --prefix web-app\"",
    "dev:all": "concurrently \"npm:start --prefix mcp-tool\" \"npm:start --prefix web-app\" \"npm:dev --prefix nextjs-app\"",
    "setup": "npm install && npm install --prefix mcp-tool && npm install --prefix web-app && npm install --prefix nextjs-app",
    "dev:bootstrap": "npm run setup && npm run dev"
  },
  "dependencies": {
    "csv-parser": "^3.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  ,
    "concurrently": "^8.2.0"
  }
}
